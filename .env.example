# 应用配置
NEXT_PUBLIC_APP_NAME=LMAICloud
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API 配置 (开发模式: 直连后端)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# WebSocket URL (留空则自动从 API_URL 推导: http→ws, 去掉 /api/v1)
NEXT_PUBLIC_WS_URL=

# ---- Nginx 统一入口模式 ----
# 前端和后端都通过 Nginx 80/443 端口访问, 无需跨域
# NEXT_PUBLIC_APP_URL=http://your-domain.com
# NEXT_PUBLIC_API_URL=http://your-domain.com/api/v1
# NEXT_PUBLIC_WS_URL=
